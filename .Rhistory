t_amostra <- as.matrix(read.table("dados/Ex1_t", header = TRUE))
x_entrada <- as.matrix(read.table("dados/Ex1_x", header = TRUE))
y_saida   <- as.matrix(read.table("dados/Ex1_y", header = TRUE))

# Número total de amostraas
n_total <- nrow(x_entrada)

#pegar 70% dos dados para treino e deixar 30% para teste
indices_treino <- sample(1:n_total, size = floor(0.7 * n_total))

x_treino <- as.matrix(x_entrada[indices_treino, ])
y_treino <- as.matrix(y_saida[indices_treino, ])

x_teste <- as.matrix(x_entrada[-indices_treino, ])
y_teste <- as.matrix(y_saida[-indices_treino, ])
t_teste <- as.matrix(t_amostra[-indices_treino, ])


trainadaline <- function(xin, yd, eta, tol, maxepocas, par) {
  dimxin <- dim(xin)
  N <- dimxin[1] 
  n <- dimxin[2] 
  
  if (par == 1) {
    wt <- as.matrix(runif(n + 1) - 0.5)
    xin <- cbind(1, xin)
  } else {
    wt <- as.matrix(runif(n) - 0.5)
  }
  
  nepocas <- 0
  eepoca <- tol + 1
  evec <- matrix(nrow = 1, ncol = maxepocas)
  
  while ((nepocas < maxepocas) && (eepoca > tol)) {
    ei2 <- 0
    xseq <- sample(N) 
    
    for (i in 1:N) {
      irand <- xseq[i]
      xvec <- as.matrix(xin[irand, ])
      yhati <- t(xvec) %*% wt
      ei <- yd[irand, 1] - as.numeric(yhati)
      dw <- eta * ei * xvec
      wt <- wt + dw
      ei2 <- ei2 + ei^2
    }
    
    nepocas <- nepocas + 1
    evec[nepocas] <- ei2 / N 
    eepoca <- evec[nepocas]
  }
  
  return(list(wt = wt, evec = evec[1:nepocas]))
}


# par = 1 ativa o bias (calcula o 'a' da fórmula y = a + bx)
resultado <- trainadaline(xin = x_treino, 
                          yd = y_treino, 
                          eta = 0.01,       # Taxa de aprendizado
                          tol = 1e-4,       # Tolerância
                          maxepocas = 1000, 
                          par = 1)


pesos <- resultado_ex1$wt
cat("--- Resultado do Modelo ---\n")
cat("Coeficiente 'a' (Bias):", pesos[1], "\n")
cat("Coeficiente 'b' (Peso de x):", pesos[2], "\n")
cat("Equação final: y =", pesos[1], "+", pesos[2], "* x\n")

# Avaliação e Teste
# Para prever, multiplicamos os dados de teste pelos pesos.
# Como usamos par = 1, precisamos colocar a coluna de 1 (bias) nos dados de teste.
x_teste_bias <- cbind(1, x_teste)
y_previsto <- x_teste_bias %*% pesos

# Visualização Gráfica
par(mfrow=c(1,2)) # Divide a tela para 2 gráficos

# Gráfico 1: Curva de Erro
plot(resultado_ex1$evec, type = 'l', col = "blue", lwd = 2,
     xlab = "Época", ylab = "Erro Quadrático", 
     main = "Convergência do Treinamento")

# Gráfico 2: Comparação Visual (Original vs Previsto)

# Ordenando os dados de teste pelo tempo para o gráfico ficar com a linha contínua correta
ordem <- order(t_teste)
t_plot <- t_teste[ordem]
y_teste_plot <- y_teste[ordem]
y_previsto_plot <- y_previsto[ordem]

plot(t_plot, y_teste_plot, type = "p", col = "black", pch = 16, 
     xlab = "Tempo (t)", ylab = "Sinal de Saída (y)", 
     main = "Teste: Original vs Previsto")

lines(t_plot, y_previsto_plot, col = "green", lwd = 2, type = "b", pch = 1)

legend("bottomleft", legend = c("Original", "Previsto"), 
       col = c("black", "green"), pch = c(16, 1), lty = c(NA, 1))


